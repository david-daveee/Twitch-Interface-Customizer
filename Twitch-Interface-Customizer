    function getChatMessageRoot(element) {
        if (!element) {
            return null;
        }

        return (
            element.closest('.seventv-message') ||
            element.closest(
                '[class*="seventv-message"]'
            ) ||
            element.closest(
                '[class*="seventv-chat-message"]'
            ) ||
            element.closest(
                '[data-7tv-message-id]'
            ) ||
            element.closest(
                '[data-seventv-message-id]'
            ) ||
            element.closest(
                '[data-a-target="chat-line-message"]'
            ) ||
            element.closest(
                '[data-test-selector="chat-line-message"]'
            ) ||
            element.closest(
                '.chat-line__message'
            ) ||
            element
        );
    }

    function findChatLines() {
        const lines =
            new Set();

        const selectors = [
            '.seventv-message',
            '[class*="seventv-message"]',
            '[class*="seventv-chat-message"]',
            '[data-7tv-message-id]',
            '[data-seventv-message-id]',

            '[data-a-target="chat-line-message"]',
            '[data-test-selector="chat-line-message"]',
            '.chat-line__message'
        ];

        document
            .querySelectorAll(
                selectors.join(', ')
            )
            .forEach(element => {
                const root =
                    getChatMessageRoot(
                        element
                    );

                if (
                    root &&
                    !isChatFilterElement(root)
                ) {
                    lines.add(root);
                }
            });

        document
            .querySelectorAll(
                [
                    '.chat-author__display-name',
                    '[data-a-target="chat-message-username"]',
                    '[data-test-selector="message-username"]',
                    '[data-test-selector="chat-message-username"]',
                    '[data-a-user]'
                ].join(', ')
            )
            .forEach(usernameElement => {
                const root =
                    getChatMessageRoot(
                        usernameElement
                    );

                if (
                    root &&
                    !isChatFilterElement(root)
                ) {
                    lines.add(root);
                }
            });

        return [...lines];
    }

    function findChatUsernameElement(line) {
        const selectors = [
            '.seventv-chat-user-username',
            '.seventv-user-name',
            '.seventv-username',
            '[class*="seventv"][class*="username"]',
            '[class*="seventv"][class*="user-name"]',

            '.chat-author__display-name',
            'span.chat-author__display-name',
            '[data-a-target="chat-message-username"]',
            '[data-test-selector="message-username"]',
            '[data-test-selector="chat-message-username"]',
            '[data-a-user]',
            '[data-user]',
            '[data-a-username]'
        ];

        for (
            const selector of selectors
        ) {
            const element =
                line.querySelector(
                    selector
                );

            if (
                element &&
                !isChatFilterElement(
                    element
                )
            ) {
                return element;
            }
        }

        return null;
    }

    function usernameFromElement(element) {
        if (!element) {
            return '';
        }

        const values = [
            element.getAttribute(
                'data-a-user'
            ),
            element.getAttribute(
                'data-user'
            ),
            element.getAttribute(
                'data-a-username'
            ),
            element.getAttribute(
                'data-username'
            ),
            element.getAttribute(
                'aria-label'
            ),
            element.textContent
        ];

        for (const value of values) {
            const username =
                normalizeUsername(
                    value
                );

            if (
                username &&
                username.length <= 50 &&
                !username.includes(' ') &&
                !username.includes('\n')
            ) {
                return username;
            }
        }

        return '';
    }

    function usernameFromLineText(line) {
        const text =
            String(
                line.textContent || ''
            )
                .replace(/\s+/g, ' ')
                .trim();

        const patterns = [
            /(?:AM|PM)\s+([a-zA-Z0-9_]{1,50})\s*:/i,
            /\d{1,2}:\d{2}\s+([a-zA-Z0-9_]{1,50})\s*:/i,
            /(?:^|\s)([a-zA-Z0-9_]{1,50})\s*:/
        ];

        for (const pattern of patterns) {
            const match =
                text.match(pattern);

            if (match?.[1]) {
                return normalizeUsername(
                    match[1]
                );
            }
        }

        return '';
    }

    function getLineUsername(line) {
        return (
            usernameFromElement(
                findChatUsernameElement(
                    line
                )
            ) ||
            usernameFromLineText(
                line
            )
        );
    }

    function findChatMessageBody(line) {
        const selectors = [
            '.seventv-message-content',
            '.seventv-chat-message-content',
            '[class*="seventv"][class*="message-content"]',
            '[class*="seventv"][class*="message-body"]',

            '[data-a-target="chat-line-message-body"]',
            '[data-a-target="chat-message-text"]',
            '[data-test-selector="chat-message-text"]',
            '.chat-line__message-container'
        ];

        for (
            const selector of selectors
        ) {
            const body =
                line.querySelector(
                    selector
                );

            if (body) {
                return body;
            }
        }

        return line;
    }

    function collectVisibleChatUsers() {
        const users =
            new Map();

        findChatLines()
            .forEach(line => {
                const username =
                    getLineUsername(line);

                if (!username) {
                    return;
                }

                users.set(
                    username,
                    (users.get(username) || 0) + 1
                );
            });

        hiddenChatUsers.forEach(
            username => {
                if (!users.has(username)) {
                    users.set(
                        username,
                        0
                    );
                }
            }
        );

        return [...users.entries()]
            .sort(
                (first, second) => {
                    if (
                        second[1] !==
                        first[1]
                    ) {
                        return (
                            second[1] -
                            first[1]
                        );
                    }

                    return first[0]
                        .localeCompare(
                            second[0]
                        );
                }
            );
    }

    // =========================================================
    // FEATURE 3 — MENTION FILTER
    // =========================================================

    function isChatUsernameNode(element) {
        if (!element) {
            return false;
        }

        return Boolean(
            element.closest(
                [
                    '.seventv-chat-user-username',
                    '.seventv-user-name',
                    '.seventv-username',
                    '[class*="seventv"][class*="username"]',
                    '[class*="seventv"][class*="user-name"]',
                    '.chat-author__display-name',
                    '[data-a-target="chat-message-username"]',
                    '[data-test-selector="message-username"]',
                    '[data-test-selector="chat-message-username"]'
                ].join(', ')
            )
        );
    }

    function collectChatTextNodes(root) {
        const nodes = [];

        const walker =
            document.createTreeWalker(
                root,
                NodeFilter.SHOW_TEXT,
                {
                    acceptNode(node) {
                        const parent =
                            node.parentElement;

                        if (!parent) {
                            return NodeFilter
                                .FILTER_REJECT;
                        }

                        if (
                            isChatUsernameNode(
                                parent
                            ) ||
                            isChatFilterElement(
                                parent
                            )
                        ) {
                            return NodeFilter
                                .FILTER_REJECT;
                        }

                        if (
                            parent.matches(
                                'script, style'
                            )
                        ) {
                            return NodeFilter
                                .FILTER_REJECT;
                        }

                        return NodeFilter
                            .FILTER_ACCEPT;
                    }
                }
            );

        let node;

        while (
            (node = walker.nextNode())
        ) {
            nodes.push(node);
        }

        return nodes;
    }

    function getOriginalChatTextRecord(
        node
    ) {
        const currentText =
            node.nodeValue || '';

        let record =
            originalChatTextNodes.get(
                node
            );

        if (!record) {
            record = {
                original: currentText,
                filtered: currentText
            };

            originalChatTextNodes.set(
                node,
                record
            );

            return record;
        }

        if (
            currentText !== record.original &&
            currentText !== record.filtered
        ) {
            record.original =
                currentText;

            record.filtered =
                currentText;
        }

        return record;
    }

    function restoreChatMessageText(body) {
        collectChatTextNodes(body)
            .forEach(node => {
                const record =
                    getOriginalChatTextRecord(
                        node
                    );

                node.nodeValue =
                    record.original;
            });
    }

    function removeHiddenChatNames(text) {
        let result =
            String(text || '');

        hiddenChatUsers.forEach(
            username => {
                if (!username) {
                    return;
                }

                const escaped =
                    escapeRegExp(
                        username
                    );

                const expression =
                    new RegExp(
                        `@?${escaped}(?![\\w])`,
                        'gi'
                    );

                result =
                    result.replace(
                        expression,
                        ''
                    );
            }
        );

        return result
            .replace(/[ \t]{2,}/g, ' ')
            .replace(
                /\s+([,.;:!?])/g,
                '$1'
            )
            .replace(
                /^[,.;:!?\s]+/,
                ''
            )
            .trim();
    }

    function filterChatMessageText(body) {
        collectChatTextNodes(body)
            .forEach(node => {
                const record =
                    getOriginalChatTextRecord(
                        node
                    );

                record.filtered =
                    removeHiddenChatNames(
                        record.original
                    );

                node.nodeValue =
                    record.filtered;
            });
    }

    function getVisibleChatMessageText(
        body
    ) {
        const clone =
            body.cloneNode(true);

        clone
            .querySelectorAll(
                [
                    '.seventv-chat-user-username',
                    '.seventv-user-name',
                    '.seventv-username',
                    '[class*="seventv"][class*="username"]',
                    '[class*="seventv"][class*="user-name"]',
                    '.chat-author__display-name',
                    '[data-a-target="chat-message-username"]',
                    '[data-test-selector="message-username"]',
                    '[data-test-selector="chat-message-username"]'
                ].join(', ')
            )
            .forEach(element => {
                element.remove();
            });

        return String(
            clone.textContent || ''
        )
            .replace(/\s+/g, ' ')
            .trim();
    }

    function applyChatFilter() {
        findChatLines()
            .forEach(line => {
                const username =
                    getLineUsername(line);

                if (!username) {
                    return;
                }

                const body =
                    findChatMessageBody(
                        line
                    );

                restoreChatMessageText(
                    body
                );

                line.classList.remove(
                    'tm-chat-filter-hidden-message'
                );

                if (
                    hiddenChatUsers.has(
                        username
                    )
                ) {
                    line.classList.add(
                        'tm-chat-filter-hidden-message'
                    );

                    return;
                }

                if (
                    hiddenChatUsers.size > 0
                ) {
                    filterChatMessageText(
                        body
                    );

                    if (
                        !getVisibleChatMessageText(
                            body
                        )
                    ) {
                        line.classList.add(
                            'tm-chat-filter-hidden-message'
                        );
                    }
                }
            });
    }

    function restoreAllChatMessages() {
        findChatLines()
            .forEach(line => {
                line.classList.remove(
                    'tm-chat-filter-hidden-message'
                );

                restoreChatMessageText(
                    findChatMessageBody(
                        line
                    )
                );
            });
    }

    // =========================================================
    // FEATURE 3 — FIND STREAM CHAT HEADER
    // =========================================================

    function findStreamChatTitle() {
        const candidates = [
            ...document.querySelectorAll(
                'h1, h2, h3, span, div, p'
            )
        ];

        return candidates.find(
            element => {
                if (
                    !isVisible(element) ||
                    isChatFilterElement(
                        element
                    )
                ) {
                    return false;
                }

                const ownText = [
                    ...element.childNodes
                ]
                    .filter(node => {
                        return (
                            node.nodeType ===
                            Node.TEXT_NODE
                        );
                    })
                    .map(node => {
                        return node.textContent;
                    })
                    .join(' ')
                    .trim();

                const text =
                    ownText ||
                    String(
                        element.textContent ||
                        ''
                    ).trim();

                return (
                    text === 'Stream Chat' ||
                    text === 'Chat' ||
                    text ===
                        'Чат трансляции'
                );
            }
        ) || null;
    }

    function findChatHeader() {
        const title =
            findStreamChatTitle();

        if (!title) {
            return null;
        }

        let current =
            title;

        for (
            let level = 0;
            level < 7 && current;
            level++
        ) {
            const rect =
                current
                    .getBoundingClientRect();

            const computedStyle =
                getComputedStyle(
                    current
                );

            const buttons = [
                ...current.querySelectorAll(
                    'button, [role="button"]'
                )
            ].filter(button => {
                if (
                    !isVisible(button) ||
                    isChatFilterElement(
                        button
                    )
                ) {
                    return false;
                }

                const buttonRect =
                    button
                        .getBoundingClientRect();

                return (
                    buttonRect.top <
                        rect.bottom &&
                    buttonRect.bottom >
                        rect.top
                );
            });

            const looksLikeHeader =
                rect.height >= 35 &&
                rect.height <= 70 &&
                rect.width >= 180 &&
                (
                    computedStyle.display ===
                        'flex' ||
                    computedStyle.display ===
                        'grid' ||
                    buttons.length > 0
                );

            if (looksLikeHeader) {
                return current;
            }

            current =
                current.parentElement;
        }

        return title.parentElement;
    }

    function findCommunityButton() {
        const header =
            findChatHeader();

        if (!header) {
            return null;
        }

        const exactSelectors = [
            'button[data-a-target="chat-viewer-list-button"]',
            '[data-a-target="chat-viewer-list-button"]',
            'button[aria-label*="Community" i]',
            'button[title*="Community" i]',
            'button[aria-label*="Users in Chat" i]',
            'button[title*="Users in Chat" i]',
            'button[aria-label*="Viewers" i]',
            'button[title*="Viewers" i]',
            'button[aria-label*="Сообщество" i]',
            'button[title*="Сообщество" i]'
        ];

        for (
            const selector of
            exactSelectors
        ) {
            const element =
                header.querySelector(
                    selector
                );

            if (
                element &&
                isVisible(element) &&
                !isChatFilterElement(
                    element
                )
            ) {
                return (
                    element.closest(
                        'button'
                    ) ||
                    element.closest(
                        '[role="button"]'
                    ) ||
                    element
                );
            }
        }

        const headerRect =
            header.getBoundingClientRect();

        const buttons = [
            ...header.querySelectorAll(
                'button, [role="button"]'
            )
        ].filter(button => {
            if (
                !isVisible(button) ||
                isChatFilterElement(
                    button
                )
            ) {
                return false;
            }

            const rect =
                button
                    .getBoundingClientRect();

            return (
                rect.width >= 20 &&
                rect.width <= 55 &&
                rect.height >= 20 &&
                rect.height <= 55 &&
                rect.top >=
                    headerRect.top - 5 &&
                rect.bottom <=
                    headerRect.bottom + 5
            );
        });

        if (
            buttons.length === 0
        ) {
            return null;
        }

        buttons.sort(
            (first, second) => {
                return (
                    second
                        .getBoundingClientRect()
                        .left -
                    first
                        .getBoundingClientRect()
                        .left
                );
            }
        );

        return buttons[0];
    }

