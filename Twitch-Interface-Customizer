    // =========================================================
    // FEATURE 1 — SIDEBAR FILTER
    // =========================================================

    function applySidebarFilter() {
        const cards =
            document.querySelectorAll(
                [
                    '[data-a-target="side-nav-card"]',
                    '.side-nav-card',
                    '[data-a-target="side-nav-arrow-card"]'
                ].join(', ')
            );

        cards.forEach(card => {
            const nameElement =
                card.querySelector(
                    [
                        'p[data-a-target="side-nav-card-metadata-username"]',
                        '.side-nav-card__title',
                        'span[title]'
                    ].join(', ')
                );

            if (!nameElement) {
                return;
            }

            const streamerName =
                normalizeUsername(
                    nameElement.textContent
                );

            const mainContainer =
                card.closest(
                    '[data-a-target="side-nav-card"]'
                ) ||
                card.closest('.side-nav-card') ||
                card;

            if (
                hiddenStreamers.includes(
                    streamerName
                ) &&
                !isSidebarEditMode
            ) {
                mainContainer.style.display =
                    'none';
            } else {
                mainContainer.style.display =
                    '';
            }

            let checkbox =
                mainContainer.querySelector(
                    '.streamer-filter-chk'
                );

            if (!checkbox) {
                checkbox =
                    document.createElement('input');

                checkbox.type = 'checkbox';

                checkbox.className =
                    'streamer-filter-chk';

                checkbox.addEventListener(
                    'click',
                    event => {
                        event.stopPropagation();
                    }
                );

                checkbox.addEventListener(
                    'change',
                    () => {
                        if (checkbox.checked) {
                            if (
                                !tempHiddenStreamers
                                    .includes(
                                        streamerName
                                    )
                            ) {
                                tempHiddenStreamers
                                    .push(
                                        streamerName
                                    );
                            }
                        } else {
                            tempHiddenStreamers =
                                tempHiddenStreamers
                                    .filter(
                                        name =>
                                            name !==
                                            streamerName
                                    );
                        }
                    }
                );

                const link =
                    mainContainer
                        .querySelector('a') ||
                    mainContainer.firstChild;

                if (link) {
                    link.style.display =
                        'flex';

                    link.style.alignItems =
                        'center';

                    link.insertBefore(
                        checkbox,
                        link.firstChild
                    );
                }
            }

            checkbox.checked =
                tempHiddenStreamers
                    .includes(
                        streamerName
                    );

            checkbox.classList.toggle(
                'show',
                isSidebarEditMode
            );
        });
    }

    function injectSidebarControls() {
        const sidebar =
            document.querySelector(
                [
                    '[data-a-target="side-nav-bar"]',
                    '.side-nav-bar'
                ].join(', ')
            );

        if (
            !sidebar ||
            document.querySelector(
                '.custom-filter-container'
            )
        ) {
            return;
        }

        const container =
            document.createElement('div');

        container.className =
            'custom-filter-container';

        container.style.position =
            'relative';

        const toggle =
            document.createElement('button');

        toggle.type = 'button';

        toggle.className =
            'custom-filter-btn';

        toggle.textContent =
            '⚙ Filter list';

        const box =
            document.createElement('div');

        box.className =
            'custom-filter-box';

        box.innerHTML = `
            <div style="
                font-size: 13px;
                font-weight: 600;
            ">
                Select streamers to hide:
            </div>

            <div class="custom-box-actions">
                <button
                    type="button"
                    class="custom-box-btn btn-save"
                >
                    Save
                </button>

                <button
                    type="button"
                    class="custom-box-btn btn-reset"
                >
                    Reset
                </button>
            </div>
        `;

        container.append(
            toggle,
            box
        );

        sidebar.insertBefore(
            container,
            sidebar.firstChild
        );

        toggle.addEventListener(
            'click',
            () => {
                isSidebarEditMode =
                    !isSidebarEditMode;

                if (isSidebarEditMode) {
                    tempHiddenStreamers =
                        [...hiddenStreamers];
                }

                box.classList.toggle(
                    'active',
                    isSidebarEditMode
                );

                applySidebarFilter();
            }
        );

        box.querySelector('.btn-save')
            .addEventListener(
                'click',
                event => {
                    event.stopPropagation();

                    hiddenStreamers =
                        [...tempHiddenStreamers];

                    GM_setValue(
                        'hiddenStreamers',
                        hiddenStreamers
                    );

                    isSidebarEditMode =
                        false;

                    box.classList.remove(
                        'active'
                    );

                    applySidebarFilter();
                }
            );

        box.querySelector('.btn-reset')
            .addEventListener(
                'click',
                event => {
                    event.stopPropagation();

                    hiddenStreamers = [];
                    tempHiddenStreamers = [];

                    GM_setValue(
                        'hiddenStreamers',
                        []
                    );

                    isSidebarEditMode =
                        false;

                    box.classList.remove(
                        'active'
                    );

                    applySidebarFilter();
                }
            );
    }

    // =========================================================
    // FEATURE 2 — CONTROL IDENTIFICATION
    // =========================================================

    function getControlText(element) {
        const values = [
            element.textContent,
            element.getAttribute(
                'aria-label'
            ),
            element.getAttribute(
                'title'
            ),
            element.getAttribute(
                'data-a-target'
            ),
            element.getAttribute(
                'data-test-selector'
            )
        ];

        element
            .querySelectorAll(
                [
                    '[aria-label]',
                    '[title]',
                    '[data-a-target]',
                    '[data-test-selector]'
                ].join(', ')
            )
            .forEach(child => {
                values.push(
                    child.getAttribute(
                        'aria-label'
                    ),
                    child.getAttribute(
                        'title'
                    ),
                    child.getAttribute(
                        'data-a-target'
                    ),
                    child.getAttribute(
                        'data-test-selector'
                    )
                );
            });

        return normalizeText(
            values.join(' ')
        );
    }

    function hasSelector(
        element,
        selectors
    ) {
        return selectors.some(
            selector => {
                try {
                    return (
                        element.matches(
                            selector
                        ) ||
                        Boolean(
                            element.querySelector(
                                selector
                            )
                        )
                    );
                } catch {
                    return false;
                }
            }
        );
    }

    function isInTopNav(element) {
        return Boolean(
            element.closest(
                [
                    'nav',
                    'header',
                    '[data-a-target="top-nav-container"]',
                    '[data-test-selector*="top-nav"]',
                    '.top-nav',
                    '[class*="top-nav"]'
                ].join(', ')
            )
        );
    }

    function isInChatInput(element) {
        return Boolean(
            element.closest(
                [
                    '[data-a-target="chat-input"]',
                    '[data-a-target="chat-input-container"]',
                    '[data-test-selector*="chat-input"]',
                    '.chat-input',
                    '[class*="chat-input"]'
                ].join(', ')
            )
        );
    }

    function identifyControl(element) {
        if (!(element instanceof HTMLElement)) {
            return null;
        }

        if (
            element.classList.contains(
                'channel-customize-btn'
            ) ||
            isChatFilterElement(element)
        ) {
            return null;
        }

        if (
            element.closest(
                [
                    '[data-a-target="side-nav-bar"]',
                    '.side-nav-bar'
                ].join(', ')
            )
        ) {
            return null;
        }

        const text =
            getControlText(element);

        const top =
            isInTopNav(element);

        const chat =
            isInChatInput(element);

        if (
            top &&
            (
                hasSelector(element, [
                    '[data-a-target*="ad-free"]',
                    '[data-test-selector*="ad-free"]',
                    '[data-a-target*="turbo"]'
                ]) ||
                text.includes('ad-free') ||
                text.includes('ad free') ||
                text.includes('try 1-month') ||
                text.includes('try 1 month')
            )
        ) {
            return 'topAdFree';
        }

        if (
            top &&
            (
                hasSelector(element, [
                    '[data-a-target*="prime"]',
                    '[data-test-selector*="prime"]',
                    '[data-a-target*="loot"]'
                ]) ||
                text.includes('prime gaming') ||
                text.includes('prime loot')
            )
        ) {
            return 'topPrime';
        }

        if (
            top &&
            (
                hasSelector(element, [
                    '[data-a-target*="whisper"]',
                    '[data-test-selector*="whisper"]',
                    '[data-a-target*="message"]'
                ]) ||
                text.includes('whisper') ||
                text.includes('direct message')
            )
        ) {
            return 'topWhispers';
        }

        if (
            top &&
            (
                hasSelector(element, [
                    '[data-a-target*="drop"]',
                    '[data-test-selector*="drop"]',
                    '[data-a-target*="reward"]'
                ]) ||
                text.includes('drops') ||
                text.includes('rewards')
            )
        ) {
            return 'topDrops';
        }

        if (
            top &&
            (
                hasSelector(element, [
                    '[data-a-target*="notification"]',
                    '[data-test-selector*="notification"]',
                    '[data-a-target*="inbox"]'
                ]) ||
                text.includes('notification') ||
                text.includes('inbox')
            )
        ) {
            return 'topNotifications';
        }

        if (
            hasSelector(element, [
