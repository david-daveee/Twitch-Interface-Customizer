        if (
            !communityButton ||
            !communityButton.parentElement
        ) {
            return;
        }

        let root =
            document.querySelector(
                '.tm-chat-filter-header-root'
            );

        if (!root) {
            root =
                document.createElement(
                    'div'
                );

            root.className =
                'tm-chat-filter-header-root';

            const button =
                document.createElement(
                    'button'
                );

            button.type =
                'button';

            button.className =
                'tm-chat-filter-header-button';

            button.title =
                'Hide chat users';

            button.setAttribute(
                'aria-label',
                'Hide chat users'
            );

            button.innerHTML =
                chatFilterIconSvg();

            root.appendChild(
                button
            );

            button.addEventListener(
                'click',
                event => {
                    stopEvent(event);

                    isChatPanelOpen =
                        !isChatPanelOpen;

                    if (
                        isChatPanelOpen
                    ) {
                        draftHiddenChatUsers =
                            new Set(
                                hiddenChatUsers
                            );

                        renderChatUserList();

                        requestAnimationFrame(
                            positionChatPanel
                        );
                    }

                    updateChatPanelVisibility();
                },
                true
            );
        }

        if (
            root.parentElement !==
                communityButton.parentElement ||
            root.nextElementSibling !==
                communityButton
        ) {
            communityButton
                .parentElement
                .insertBefore(
                    root,
                    communityButton
                );
        }
    }

    // =========================================================
    // FEATURE 3 — PANEL
    // =========================================================

    function createChatPanel() {
        if (
            chatPanel &&
            chatPanel.isConnected
        ) {
            return;
        }

        chatPanel =
            document.createElement(
                'div'
            );

        chatPanel.className =
            'tm-chat-filter-panel';

        const titleRow =
            document.createElement(
                'div'
            );

        titleRow.className =
            'tm-chat-filter-title-row';

        const title =
            document.createElement(
                'div'
            );

        title.className =
            'tm-chat-filter-title';

        title.textContent =
            'Hide chat users';

        const count =
            document.createElement(
                'div'
            );

        count.className =
            'tm-chat-filter-count';

        titleRow.append(
            title,
            count
        );

        chatUsersContainer =
            document.createElement(
                'div'
            );

        chatUsersContainer.className =
            'tm-chat-filter-users';

        const actions =
            document.createElement(
                'div'
            );

        actions.className =
            'tm-chat-filter-actions';

        const saveButton =
            document.createElement(
                'button'
            );

        saveButton.type =
            'button';

        saveButton.className =
            'tm-chat-filter-action ' +
            'tm-chat-filter-save';

        saveButton.textContent =
            'Save';

        const resetButton =
            document.createElement(
                'button'
            );

        resetButton.type =
            'button';

        resetButton.className =
            'tm-chat-filter-action ' +
            'tm-chat-filter-reset';

        resetButton.textContent =
            'Reset';

        const refreshButton =
            document.createElement(
                'button'
            );

        refreshButton.type =
            'button';

        refreshButton.className =
            'tm-chat-filter-action ' +
            'tm-chat-filter-refresh';

        refreshButton.textContent =
            '↻';

        refreshButton.title =
            'Refresh user list';

        actions.append(
            saveButton,
            resetButton,
            refreshButton
        );

        chatPanel.append(
            titleRow,
            chatUsersContainer,
            actions
        );

        document.body.appendChild(
            chatPanel
        );

        saveButton.addEventListener(
            'click',
            event => {
                stopEvent(event);

                hiddenChatUsers =
                    new Set(
                        draftHiddenChatUsers
                    );

                saveHiddenChatUsers();

                isChatPanelOpen =
                    false;

                updateChatPanelVisibility();
                applyChatFilter();
            },
            true
        );

        resetButton.addEventListener(
            'click',
            event => {
                stopEvent(event);

                hiddenChatUsers.clear();
                draftHiddenChatUsers.clear();

                saveHiddenChatUsers();

                restoreAllChatMessages();
                renderChatUserList();
                applyChatFilter();
            },
            true
        );

        refreshButton.addEventListener(
            'click',
            event => {
                stopEvent(event);

                renderChatUserList();
                positionChatPanel();
            },
            true
        );
    }

    function renderChatUserList() {
        createChatPanel();

        chatUsersContainer.textContent =
            '';

        const users =
            collectVisibleChatUsers();

        const countElement =
            chatPanel.querySelector(
                '.tm-chat-filter-count'
            );

        if (countElement) {
            countElement.textContent =
                `${users.length} users`;
        }

        if (
            users.length === 0
        ) {
            const empty =
                document.createElement(
                    'div'
                );

            empty.className =
                'tm-chat-filter-empty-list';

            empty.textContent =
                'No users found in chat yet';

            chatUsersContainer
                .appendChild(
                    empty
                );

            return;
        }

        users.forEach(
            ([
                username,
                messageCount
            ]) => {
                const row =
                    document.createElement(
                        'label'
                    );

                row.className =
                    'tm-chat-filter-user-row';

                const checkbox =
                    document.createElement(
                        'input'
                    );

                checkbox.type =
                    'checkbox';

                checkbox.className =
                    'tm-chat-filter-user-checkbox';

                checkbox.checked =
                    draftHiddenChatUsers
                        .has(username);

                const name =
                    document.createElement(
                        'span'
                    );

                name.className =
                    'tm-chat-filter-user-name';

                name.textContent =
                    username;

                const status =
                    document.createElement(
                        'span'
                    );

                status.className =
                    'tm-chat-filter-user-status';

                status.textContent =
                    messageCount > 0
                        ? String(
                            messageCount
                        )
                        : 'hidden';

                checkbox.addEventListener(
                    'change',
                    () => {
                        if (
                            checkbox.checked
                        ) {
                            draftHiddenChatUsers
                                .add(
                                    username
                                );
                        } else {
                            draftHiddenChatUsers
                                .delete(
                                    username
                                );
                        }
                    }
                );

                row.append(
                    checkbox,
                    name,
                    status
                );

                chatUsersContainer
                    .appendChild(
                        row
                    );
            }
        );
    }

    function positionChatPanel() {
        createChatPanel();

        const button =
            document.querySelector(
                '.tm-chat-filter-header-button'
            );

        const header =
            findChatHeader();

        if (
            !button ||
            !header
        ) {
            return;
        }

        const buttonRect =
            button.getBoundingClientRect();

        const headerRect =
            header.getBoundingClientRect();

        const panelWidth =
            265;

        const gap =
            7;

        let left =
            buttonRect.right -
            panelWidth;

        left = Math.max(
            headerRect.left + 5,
            Math.min(
                left,
                headerRect.right -
                    panelWidth -
                    5
            )
        );

        let top =
            headerRect.bottom +
            gap;

        const panelHeight =
            Math.min(
                470,
                chatPanel.scrollHeight ||
                    470
            );

        if (
            top + panelHeight >
            window.innerHeight - 6
        ) {
            top = Math.max(
                6,
                buttonRect.top -
                    panelHeight -
                    gap
            );
        }

        chatPanel.style.left =
            `${Math.round(left)}px`;

        chatPanel.style.top =
            `${Math.round(top)}px`;
    }

    function updateChatPanelVisibility() {
        createChatPanel();

        chatPanel.classList.toggle(
            'show',
            isChatPanelOpen
        );

        const button =
            document.querySelector(
                '.tm-chat-filter-header-button'
            );

        button?.classList.toggle(
            'active',
            isChatPanelOpen
        );
    }

    // =========================================================
    // GLOBAL REFRESH
    // =========================================================

    let refreshScheduled =
        false;

    function refreshAll() {
        injectSidebarControls();
        applySidebarFilter();

        injectInterfaceButton();
        applyInterfaceVisibility();

        injectChatHeaderButton();
        createChatPanel();
        applyChatFilter();

        if (isChatPanelOpen) {
            positionChatPanel();
        }
    }

    function scheduleRefresh() {
        if (refreshScheduled) {
            return;
        }

        refreshScheduled =
            true;

        requestAnimationFrame(
            () => {
                refreshScheduled =
                    false;

                refreshAll();
            }
        );
    }

    const observer =
        new MutationObserver(
            mutations => {
                const relevant =
                    mutations.some(
                        mutation => {
                            return [
                                ...mutation
                                    .addedNodes
                            ].some(node => {
                                if (
                                    node.nodeType !==
                                    Node.ELEMENT_NODE
                                ) {
                                    return false;
                                }

                                return (
                                    !isChatFilterElement(
                                        node
                                    ) &&
                                    !node.classList
                                        ?.contains(
                                            'tm-control-checkbox'
                                        ) &&
                                    !node.classList
                                        ?.contains(
                                            'streamer-filter-chk'
                                        )
                                );
                            });
                        }
                    );

                if (relevant) {
                    scheduleRefresh();
                }
            }
        );

    observer.observe(
        document.body,
        {
            childList: true,
            subtree: true
        }
    );

    window.addEventListener(
        'resize',
        () => {
            if (
                isChatPanelOpen
            ) {
                positionChatPanel();
            }
        }
    );

    window.addEventListener(
        'scroll',
        () => {
            if (
                isChatPanelOpen
            ) {
                positionChatPanel();
            }
        },
        true
    );

    document.addEventListener(
        'click',
        event => {
            if (
                !isChatPanelOpen
            ) {
                return;
            }

            if (
                !(event.target instanceof Element)
            ) {
                return;
            }

            if (
                event.target.closest(
                    '.tm-chat-filter-panel'
                ) ||
                event.target.closest(
                    '.tm-chat-filter-header-root'
                )
            ) {
                return;
            }

            isChatPanelOpen =
                false;

            updateChatPanelVisibility();
        },
        true
    );

    /*
     * 7TV может самостоятельно перерисовывать сообщения,
     * поэтому чат периодически фильтруется повторно.
     */
    setInterval(
        () => {
            applyChatFilter();

            if (
                isChatPanelOpen
            ) {
                positionChatPanel();
            }
        },
        500
    );

    refreshAll();
})();
