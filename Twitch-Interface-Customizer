    const savedHiddenElements =
        GM_getValue('hiddenElements', {});

    if (
        savedHiddenElements.bits !== undefined &&
        savedHiddenElements.bitsHeader === undefined
    ) {
        savedHiddenElements.bitsHeader =
            savedHiddenElements.bits;
    }

    delete savedHiddenElements.bits;

    let hiddenElements = {
        ...defaultHiddenElements,
        ...savedHiddenElements
    };

