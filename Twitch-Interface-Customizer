    function createInterfaceCheckbox(
        element,
        key
    ) {
        const checkbox =
            document.createElement('input');

        checkbox.type = 'checkbox';

        checkbox.className =
            'tm-control-checkbox';

        checkbox.dataset.tmKey =
            key;

        checkbox.title =
            `Hide element: ${key}`;

        [
            'pointerdown',
            'mousedown',
            'mouseup',
            'click'
        ].forEach(eventName => {
            checkbox.addEventListener(
                eventName,
                event => {
                    event.stopPropagation();
                    event.stopImmediatePropagation();
                },
                true
            );
        });

        checkbox.addEventListener(
            'change',
            event => {
                event.stopPropagation();
                event.stopImmediatePropagation();

                const currentKey =
                    checkbox.dataset.tmKey;

                hiddenElements[currentKey] =
                    checkbox.checked;

                GM_setValue(
                    'hiddenElements',
                    { ...hiddenElements }
                );
            }
        );

        element.appendChild(
            checkbox
        );

        return checkbox;
    }

    function applyInterfaceVisibility() {
        document
            .querySelectorAll(
                [
                    'button',
                    'a[role="button"]',
                    '[role="button"]'
                ].join(', ')
            )
            .forEach(element => {
                const key =
                    identifyControl(element);

                if (!key) {
                    return;
                }

                element.classList.add(
                    'tm-customizable-control'
                );

                element.dataset.tmControlKey =
                    key;

                const shouldHide =
                    Boolean(
                        hiddenElements[key]
                    ) &&
                    !isInterfaceEditMode;

                if (shouldHide) {
                    element.style.setProperty(
                        'display',
                        'none',
                        'important'
                    );
                } else {
                    element.style.removeProperty(
                        'display'
                    );
                }

                let checkbox =
                    element.querySelector(
                        ':scope > .tm-control-checkbox'
                    );

                if (!checkbox) {
                    checkbox =
                        createInterfaceCheckbox(
                            element,
                            key
                        );
                }

                checkbox.dataset.tmKey =
                    key;

                checkbox.checked =
                    Boolean(
                        hiddenElements[key]
                    );

                checkbox.classList.toggle(
                    'show',
                    isInterfaceEditMode
                );

                element.classList.toggle(
                    'tm-control-editing',
                    isInterfaceEditMode
                );
            });
    }

    function blockInterfaceButton(event) {
        if (!isInterfaceEditMode) {
