    function loadHiddenChatUsers() {
        const saved =
            GM_getValue(
                CHAT_STORAGE_KEY,
                []
            );

        if (!Array.isArray(saved)) {
            return new Set();
        }

        return new Set(
            saved
                .map(normalizeUsername)
                .filter(Boolean)
        );
    }

    function saveHiddenChatUsers() {
        GM_setValue(
            CHAT_STORAGE_KEY,
            [...hiddenChatUsers]
        );
    }

